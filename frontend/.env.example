# Point the console at the FastAPI backend. LEAVE UNSET to run the fully self-contained
# in-browser simulation (this is what makes the Vercel deploy clickable with no backend).
#   local docker-compose : http://localhost:8000
#   live EC2 / RDS       : http://<ec2-public-dns>:8000  (or behind Nginx :80)
# NEXT_PUBLIC_API_URL=http://localhost:8000
